# Runtime
PORT=8787
AUTONOMY_MODE=demo
AUTO_START=true
RUN_ON_BOOT=true
RUN_INTERVAL_MS=300000

# Budget and guardrails
MAX_USD_PER_RUN=0.25
MAX_USD_PER_DAY=5
MIN_TOOL_CONFIDENCE=0.64
ALLOW_ONCHAIN_MUTATIONS=false

# SAP / Synapse
SAP_RPC_URL=https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_KEY
SAP_WALLET_PATH=keys/agent.json
SAP_AGENT_WALLET=
SAP_SENTINEL_WALLET=Ccr2yK3hLALU4p8oNRqrh4dGuvPJTth5KCLMio8cE1ph
SAP_X402_ENDPOINT=http://127.0.0.1:8787/api/x402

# Ace Data Cloud x402
ACE_PLATFORM_TOKEN=platform-v1-YOUR_TOKEN
ACE_X402_ORDER_ID=
ACE_X402_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
ACE_BASE_URL=https://platform.acedata.cloud

# Optional external signal source used by the agent's trigger step
SIGNAL_SOURCE_URL=
